# Discord Bot
DISCORD_TOKEN=your_discord_bot_token_here

# Database
DATABASE_URL=postgresql://rsibot:rsibot_secret@postgres:5432/rsibot

# Binance (optional - public data works without keys)
BINANCE_API_KEY=
BINANCE_SECRET=

# Scanner
SCAN_CRON=*/15 * * * *
# Scanner runs every 15 min - checks 4H candles for signals, positions for stop/TP hits
LOG_LEVEL=info
